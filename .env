# ============================================================
# 古代烽火台视线分析与通信网络可靠性仿真系统
# 环境变量配置
# ============================================================

# 服务器配置
SERVER_PORT=8080

# PostgreSQL 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=beacon_system

# MQTT 配置
MQTT_BROKER=mqtt-broker
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC=beacon/alerts

# 系统配置
CONNECTIVITY_THRESHOLD=0.7
DEMO_MODE=false

# 模拟器配置
SIM_INTERVAL=60
SIM_WEATHER=auto
SIM_VISIBILITY=
